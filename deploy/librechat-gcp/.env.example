# LibreChat environment — copy to .env and fill in values.
# See https://librechat.ai/docs/configuration/dotenv

# ---------- Core ----------
PORT=3080
MONGO_URI=mongodb://mongodb:27017/LibreChat
MEILI_MASTER_KEY=your-meilisearch-master-key

# Domain (for cookies and CORS)
DOMAIN_CLIENT=chat.tersona.terpedia.com
VITE_SHARED_DOMAIN=true

# ---------- AI providers (at least one required) ----------
OPENAI_API_KEY=sk-...

# Optional: Google (Gemini) for TerpeneQueen or other models
# GOOGLE_API_KEY=...

# ---------- Speech (STT/TTS) — used by librechat.yaml ----------
# If using same key as OpenAI above, no need to duplicate
# TTS_API_KEY=...
# STT_API_KEY=...

# ---------- Optional: ElevenLabs for TTS (Susan-like voice until Google Custom Voice) ----------
# ELEVENLABS_API_KEY=...

# ---------- User/auth (optional) ----------
# ALLOW_REGISTRATION=true
# ALLOW_SOCIAL_LOGIN=false

# ---------- UID/GID for Docker (Linux) — match host user to avoid permission issues ----------
# UID=1000
# GID=1000
